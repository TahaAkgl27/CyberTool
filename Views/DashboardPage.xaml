<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="CyberTool.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:CyberTool.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24" RowSpacing="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Hero Section -->
        <Grid CornerRadius="16" Padding="32">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#0F172A" Offset="0.0" />
                    <GradientStop Color="#1E293B" Offset="1.0" />
                </LinearGradientBrush>
            </Grid.Background>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            
            <StackPanel Spacing="12" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="12">
                     <FontIcon Glyph="&#xE774;" FontSize="32" Foreground="{ThemeResource SystemAccentColorLight2}"/>
                     <TextBlock Text="CyberTool" FontSize="32" FontWeight="Bold" Foreground="White" />
                </StackPanel>
                <TextBlock Text="Gelişmiş Ağ ve Uygulama Güvenliği Analiz Platformu" FontSize="16" Foreground="#94A3B8" />
                <Border Background="#33475569" HorizontalAlignment="Left" CornerRadius="4" Padding="8,4" Margin="0,8,0,0">
                    <TextBlock Text="v1.2.0 • AGENT MODE" FontSize="12" Foreground="#64748B" FontWeight="SemiBold"/>
                </Border>
            </StackPanel>

            <FontIcon Grid.Column="1" Glyph="&#xE909;" FontSize="80" Foreground="{ThemeResource SystemAccentColor}" Opacity="0.15" VerticalAlignment="Center"/>
        </Grid>

        <!-- Dashboard Cards -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid ColumnSpacing="20" RowSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Card 1: Quick Start -->
                <Border Grid.Row="0" Grid.Column="0" CornerRadius="12" BorderThickness="1" BorderBrush="#20FFFFFF">
                    <Border.Background>
                        <SolidColorBrush Color="{ThemeResource SystemChromeMediumColor}" Opacity="0.5"/>
                    </Border.Background>
                    <Grid Padding="24" RowSpacing="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Ellipse Width="40" Height="40" Fill="#15803D" />
                            <FontIcon Glyph="&#xE768;" FontSize="18" Foreground="White" Margin="-29,-1,0,0" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            <TextBlock Text="Hızlı Başlangıç" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Grid.Row="1" Text="Tarama ekranına gidip hedefi girerek (yalnızca izinli sistemlerde) temel kontrol çalıştırabilirsiniz. Hızlı, etkili ve güvenli tarama." 
                                   TextWrapping="Wrap" Opacity="0.7" LineHeight="20"/>
                    </Grid>
                </Border>

                <!-- Card 2: Security -->
                <Border Grid.Row="0" Grid.Column="1" CornerRadius="12" BorderThickness="1" BorderBrush="#20FFFFFF">
                    <Border.Background>
                        <SolidColorBrush Color="{ThemeResource SystemChromeMediumColor}" Opacity="0.5"/>
                    </Border.Background>
                    <Grid Padding="24" RowSpacing="16">
                         <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal" Spacing="12">
                             <Ellipse Width="40" Height="40" Fill="#B91C1C">
                             </Ellipse>
                             <FontIcon Glyph="&#xE72E;" FontSize="18" Foreground="White" Margin="-29,-1,0,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Güvenlik ve Yetkilendirme" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Grid.Row="1" Text="Sadece kendi sistemlerinizi veya yazılı izin aldığınız hedefleri test edin. Etik ve yasal sınırlar içinde kalın." 
                                   TextWrapping="Wrap" Opacity="0.7" LineHeight="20"/>
                    </Grid>
                </Border>

                <!-- Card 3: Reports -->
                <Border Grid.Row="1" Grid.Column="0" CornerRadius="12" BorderThickness="1" BorderBrush="#20FFFFFF">
                    <Border.Background>
                        <SolidColorBrush Color="{ThemeResource SystemChromeMediumColor}" Opacity="0.5"/>
                    </Border.Background>
                    <Grid Padding="24" RowSpacing="16">
                         <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal" Spacing="12">
                             <Ellipse Width="40" Height="40" Fill="#A855F7">
                             </Ellipse>
                             <FontIcon Glyph="&#xE9F9;" FontSize="18" Foreground="White" Margin="-29,-1,0,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Raporlar &amp; Bulgular" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Grid.Row="1" Text="Tarama çıktıları session bazlı listelenir. Her bulgu için risk seviyesi, kanıt ve çözüm önerileri sunulur." 
                                   TextWrapping="Wrap" Opacity="0.7" LineHeight="20"/>
                    </Grid>
                </Border>

                <!-- Card 4: Future -->
                <Border Grid.Row="1" Grid.Column="1" CornerRadius="12" BorderThickness="1" BorderBrush="#20FFFFFF">
                     <Border.Background>
                        <SolidColorBrush Color="{ThemeResource SystemChromeMediumColor}" Opacity="0.5"/>
                    </Border.Background>
                    <Grid Padding="24" RowSpacing="16">
                         <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal" Spacing="12">
                             <Ellipse Width="40" Height="40" Fill="#0369A1">
                             </Ellipse>
                             <FontIcon Glyph="&#xE76C;" FontSize="18" Foreground="White" Margin="-29,-1,0,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Sonraki Adımlar" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Grid.Row="1" Text="PDF/HTML raporlama, Nmap entegrasyonu ve otomatik exploit denemeleri yakında gelecek özellikler arasında." 
                                   TextWrapping="Wrap" Opacity="0.7" LineHeight="20"/>
                    </Grid>
                </Border>

            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
